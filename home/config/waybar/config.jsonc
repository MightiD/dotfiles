{
    "layer": "top", // Waybar at top layer
    "spacing": 1,

    "modules-left": [
        "hyprland/workspaces"
    ],

    "modules-center": [
        "hyprland/window"
    ],

    "modules-right": [
        "tray",
        "pulseaudio",
        "power-profiles-daemon",
        "clock"
    ],

    "hyprland/workspaces": {
        "justify": "center",
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "tooltip": false,
        "format": "{name}"
    },

    "hyprland/window": {
        "tooltip": false
    },

    "clock": {
        "justify": "center",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%H:%M - %d}"
    },

    "power-profiles-daemon": {
        "justify": "center",
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "default": "\udb85\udc0b",
            "performance": "\udb85\udc0b",
            "balanced": "\uf24e",
            "power-saver": "\udb80\udf2a"
        }
    },

    "pulseaudio": {
        "justify": "center",
        "scroll-step": 5,
        "format": "{volume}% \uf028",
        "format-muted": "\ueee8",
        "on-click": "pwvucontrol"
    },

    "tray": {
        "spacing": 5
    }
}
